---
// 根路径瞬时跳转到默认 locale（英文首页）。
// GitHub Pages 是纯静态托管，无法做服务器端 301；这里用「即时 meta-refresh
// （0 秒）+ 内联 location.replace」组合：有 JS 时脚本在 <head> 立即执行、几乎
// 无感，无 JS 时靠 content="0" 的 meta 兜底。body 留空，避免出现可见的
// “Redirecting…” 文字。canonical 指向 /en/，root 本身 noindex。
const target = `${import.meta.env.BASE_URL}en/`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Porthole</title>
  <meta name="robots" content="noindex" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <script is:inline set:html={`location.replace(${JSON.stringify(target)})`}></script>
</head>
<body></body>
</html>
