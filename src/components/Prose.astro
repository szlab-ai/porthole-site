---
const { title } = Astro.props;
---
<article class="mx-auto max-w-content px-5 py-12">
  <h1 class="mb-6 text-3xl font-bold">{title}</h1>
  <div class="space-y-4 leading-relaxed text-ink [&_a]:text-accent [&_h2]:mt-8 [&_h2]:font-semibold [&_h3]:mt-6 [&_h3]:font-semibold"><slot /></div>
</article>
