---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="mx-auto max-w-5xl px-5 pt-20 pb-16 text-center">
  <img src={`${import.meta.env.BASE_URL}porthole.svg`} alt="" width="112" height="112" class="mx-auto mb-6 h-28 w-28 rounded-2xl shadow-sm" />
  <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Porthole</h1>
  <p class="mt-3 text-xl text-ink/90">{t('hero.tagline')}</p>
  <p class="mt-2 text-muted">{t('hero.subtitle')}</p>
  <span class="mt-8 inline-block cursor-default rounded-xl border border-line bg-card px-5 py-3 text-sm font-semibold text-muted">{t('hero.cta')}</span>
</section>
