---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---
<section class="mx-auto max-w-5xl px-5 py-12 text-center">
  <p class="text-lg">{t('trust.text')}</p>
  <a href={`${base}${lang}/privacy/`} class="mt-2 inline-block text-sm text-accent">{t('trust.link')} →</a>
</section>
