---
import LangToggle from './LangToggle.astro';
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---
<footer class="mt-24 border-t border-line">
  <div class="mx-auto max-w-5xl px-5 py-10 text-sm text-muted">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
      <a href={`${base}${lang}/privacy/`} class="text-accent">{t('footer.privacy')}</a>
      <a href={`${base}${lang}/support/`} class="text-accent">{t('footer.support')}</a>
      <a href="mailto:szlab.ai@outlook.com" class="text-accent">{t('footer.contact')}</a>
      <span class="ml-auto"><LangToggle lang={lang} /></span>
    </div>
    <p class="mt-4 leading-relaxed">{t('footer.disclaimer')}</p>
  </div>
</footer>
