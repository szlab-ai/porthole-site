---
import LangToggle from './LangToggle.astro';
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;                 // '/porthole-site/'
const home = `${base}${lang}/`;
---
<header class="sticky top-0 z-10 border-b border-line bg-bg/90 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3">
    <a href={home} class="text-lg font-bold tracking-tight">Porthole</a>
    <div class="flex items-center gap-5 text-sm">
      <a href={`${home}#features`} class="text-muted hover:text-ink">{t('nav.features')}</a>
      <a href={`${base}${lang}/support/`} class="text-muted hover:text-ink">{t('nav.support')}</a>
      <a href={`${base}${lang}/privacy/`} class="text-muted hover:text-ink">{t('nav.privacy')}</a>
      <LangToggle lang={lang} />
    </div>
  </nav>
</header>
