---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hans' : 'en'}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href={`${base}brand/favicon.ico`} sizes="any" />
  <link rel="icon" type="image/png" href={`${base}brand/icon-32.png`} sizes="32x32" />
  <link rel="apple-touch-icon" href={`${base}brand/apple-touch-icon.png`} />
  <title>{title}</title>
</head>
<body class="bg-bg font-sans text-ink antialiased">
  <Header lang={lang} />
  <main><slot /></main>
  <Footer lang={lang} />
</body>
</html>
